<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base app theme using Material Components + dark mode support -->
    <style name="AppTheme" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary branding colors -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryVariant">@color/colorPrimaryDark</item>
        <item name="colorSecondary">@color/colorAccent</item>

        <!-- Surface colors -->
        <item name="colorSurface">@color/surface</item>

        <!-- Text colors -->
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorOnBackground">@color/white</item>
        <item name="colorOnSurface">@color/white</item>

        <!-- Android standard colors -->
        <item name="android:textColor">@color/white</item>
        <item name="android:windowBackground">@color/dark_background</item>

        <!-- Material Components widget styles -->
        <item name="textInputStyle">@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox</item>
        <item name="buttonStyle">@style/Widget.MaterialComponents.Button</item>
        <item name="cardViewStyle">@style/Widget.MaterialComponents.CardView</item>
    </style>

</resources>