<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <TextView
        android:id="@+id/txtChatModelPath"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Chat AI: Not selected" />

    <Button
        android:id="@+id/btnSelectChatModel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Select Chat AI Model" />

    <TextView
        android:id="@+id/txtCodeModelPath"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Code AI: Not selected"
        android:layout_marginTop="16dp" />

    <Button
        android:id="@+id/btnSelectCodeModel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Select Code AI Model" />

    <Button
        android:id="@+id/btnConfirmModels"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Confirm Models"
        android:layout_marginTop="24dp" />

</LinearLayout>